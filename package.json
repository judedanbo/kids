{
  "name": "kids-games-zone",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter platform dev",
    "build": "pnpm --filter @kids-games-zone/shared build && pnpm --filter platform build",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "create-game": "tsx scripts/create-game.ts",
    "gen:content": "pnpm --filter @kids-games-zone/audio-generator content",
    "gen:audio": "pnpm --filter @kids-games-zone/audio-generator audio",
    "gen:images": "pnpm --filter @kids-games-zone/image-generator start",
    "gen:images:pilot": "pnpm --filter @kids-games-zone/image-generator pilot",
    "gen:images:list": "pnpm --filter @kids-games-zone/image-generator list",
    "test:coverage": "pnpm -r --parallel run test -- --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fake-indexeddb": "^6.0.0",
    "framer-motion": "^11.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "serialize-javascript@<7.0.5": "^7.0.5",
      "fast-uri@<3.1.2": "^3.1.2",
      "@babel/plugin-transform-modules-systemjs@<7.29.4": "^7.29.4",
      "flatted@<3.4.2": "^3.4.2",
      "lodash-es@<4.18.0": "^4.18.0",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=4.0.0 <5.0.5": "^5.0.5",
      "postcss@<8.5.10": "^8.5.10",
      "vite@<6.4.2": "^6.4.2"
    }
  }
}
